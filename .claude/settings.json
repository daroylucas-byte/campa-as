{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run test*)",
      "Bash(npx supabase gen types*)",
      "Bash(npx supabase migration*)",
      "Bash(npx supabase db*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Read(.env.example)"
    ],
    "deny": [
      "Read(.env.local)",
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf*)",
      "Bash(curl *)",
      "Bash(npx supabase db reset)"
    ]
  },

  "env": {
    "NODE_ENV": "development"
  }
}
